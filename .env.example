# Root environment for docker-compose. Copy to .env and adjust as needed.

# ---------- Database ----------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=menu_tree
DB_PORT=5432

# ---------- Frontend (build-time, inlined) ----------
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ---------- Backend (production CORS) ----------
CORS_ALLOWED_ORIGINS=http://localhost:3000
