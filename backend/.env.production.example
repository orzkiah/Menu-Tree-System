# Production backend env (e.g. Render). DB points to managed Postgres (Neon/Supabase).
APP_ENV=production
# PORT is injected by the platform (Render/Cloud Run); APP_PORT is the local fallback.
APP_PORT=8080

# ---- Managed PostgreSQL (Neon / Supabase) ----
DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSLMODE=require

LOG_LEVEL=info

# Your deployed frontend origin (Vercel). Comma-separate multiple origins.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
